# ---------- 服务端口 ----------
# XIAOMING_SERVER_PORT=8080

# ---------- 数据库 ----------
# PostgreSQL 宿主端口；本机 5432 被占用时可改为 5433，并同步修改 DATABASE_URL。
# XIAOMING_POSTGRES_PORT=5432
# PostgreSQL 连接字符串 (Neon 需使用 sslmode=require)
# XIAOMING_DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require&prefer_simple_protocol=true

# ---------- 加密 ----------
# AES-256 加密密钥（32 字节 base64 编码），用于加密数据库中存储的敏感 token
# XIAOMING_ENCRYPTION_KEY=Z4ss+pkQgRg5xMvj+fkNsB2JD4z7hvQFrORtllXf4Wc=

# ---------- ChatGPT session token ----------
# 已废弃：当前默认代理链路只使用 Sidecar Chrome 登录态，不读取本地 token 池。
# XIAOMING_SESSION_TOKENS=token1,token2

# ---------- Playwright Sidecar ----------
# XIAOMING_SIDECAR_URL=http://127.0.0.1:3100
# XIAOMING_SIDECAR_PORT=3100
# 默认使用 CDP 模式启动本机 Chrome Stable，减少 Playwright persistent 启动参数差异。
# 如需回退旧模式，可设为 persistent。
# XIAOMING_CHROME_LAUNCH_MODE=cdp
# XIAOMING_CHROME_CDP_PORT=9222
# 登录模式默认 plain：首次验证 profile 或登录失效时，先打开无 CDP/无远程调试的普通 Chrome。
# 完成 ChatGPT 登录后退出该 Chrome，sidecar 再重新接管同一 profile。
# 如需旧行为，可设为 attached。
# XIAOMING_CHROME_LOGIN_MODE=plain
# persistent 模式使用 channel；CDP 模式优先自动查找本机 Chrome Stable，也可指定完整路径。
# XIAOMING_CHROME_CHANNEL=chrome
# XIAOMING_CHROME_EXECUTABLE_PATH=
# 默认使用 sidecar/.browser-profile。若登录被 CF 反复挑战，可改用日常 Chrome 用户数据目录；
# 使用日常目录前需要先完全退出普通 Chrome，避免 profile 锁冲突。
# macOS 示例：XIAOMING_CHROME_USER_DATA_DIR=/Users/you/Library/Application Support/Google/Chrome
# XIAOMING_CHROME_USER_DATA_DIR=
# 可选：指定 Chrome profile，如 Default、Profile 1。
# XIAOMING_CHROME_PROFILE_DIRECTORY=Default
# 如果普通 Chrome 依赖代理扩展或特定代理规则，而 sidecar 独立 profile 没有这些规则，
# 可显式指定 Chrome 代理。示例：socks5://127.0.0.1:7890 或 http://127.0.0.1:1087
# XIAOMING_CHROME_PROXY_SERVER=
# XIAOMING_CHROME_PROXY_BYPASS_LIST=<-loopback>
# 可选诊断项：不默认启用；启用后 Chrome 会显示“不受支持的命令行标记”警告。
# XIAOMING_CHROME_HOST_RESOLVER_RULES=
# 默认不启用 CSP bypass；只有确认 fetch 被 CSP 阻止时再打开。
# XIAOMING_CHROME_BYPASS_CSP=false
# 登录等待超时（毫秒），默认 15 分钟。
# XIAOMING_LOGIN_TIMEOUT_MS=900000
# sentinel PoW 最大计算时间（毫秒），避免高 difficulty 卡死 sidecar 主线程。
# XIAOMING_SENTINEL_POW_TIMEOUT_MS=12000

# ---------- Sentinel ----------
# sentinel token 缓存 TTL（秒），默认 300
# XIAOMING_SENTINEL_CACHE_TTL=300

# ---------- JWT ----------
# JWT 签名密钥
# XIAOMING_JWT_SECRET=change-me-in-production
# JWT 过期时间，默认 24h
# XIAOMING_JWT_EXPIRATION=24h

# ---------- ChatGPT ----------
# chatgpt.com 的基础 URL，默认 https://chatgpt.com
# XIAOMING_CHATGPT_BASE_URL=https://chatgpt.com
